# ── Trading engine worker ───────────────────────────────────────────────────
FROM node:22-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
COPY prisma ./prisma
RUN npm ci --no-audit --no-fund && npx prisma generate
COPY tsconfig.json vitest.config.ts ./
COPY src ./src
# tsx runs the TypeScript worker directly; restart: always in compose gives
# automatic crash recovery (state is rebuilt from Postgres on boot).
CMD ["npx", "tsx", "src/engine/index.ts"]
