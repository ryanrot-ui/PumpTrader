# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://trader:trader@localhost:5432/pumptrader"

# ── Redis (live settings, bot state, pub/sub) ─────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Optional Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Encryption ────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of bot wallet keys.
# Generate with: openssl rand -hex 32
# NEVER commit this. Rotating it invalidates stored encrypted keys.
WALLET_ENCRYPTION_KEY=""

# ── Solana ────────────────────────────────────────────────────────────────
# A dedicated RPC (Helius/Triton/QuickNode) is strongly recommended.
# Public mainnet RPC will rate-limit the scanner immediately.
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_WS_URL="wss://api.mainnet-beta.solana.com"
# Optional: Helius API key enables richer holder/transaction analysis
HELIUS_API_KEY=""

# ── Trading engine ────────────────────────────────────────────────────────
# paper | live   (paper is the default; live requires an imported bot wallet)
TRADING_MODE="paper"

# ── Notifications (all optional) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
DISCORD_WEBHOOK_URL=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
NOTIFY_EMAIL_TO=""
