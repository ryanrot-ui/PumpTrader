# ── Database ──────────────────────────────────────────────────────────────
# App runtime connection. On Neon this is the POOLED endpoint (host contains
# "-pooler"); plain Postgres works too.
DATABASE_URL="postgresql://trader:trader@localhost:5432/pumptrader"
# Direct (non-pooled) connection used ONLY to apply the schema at boot.
# LEAVE UNSET in most cases: the app/engine auto-derive it from DATABASE_URL by
# removing "-pooler" (Neon's pooler can't run the DDL `prisma db push` needs,
# which is what causes "table public.User does not exist" on first boot).
# Set this explicitly only if your direct host differs from the pooled host by
# more than "-pooler". Plain Postgres falls back to DATABASE_URL automatically.
DIRECT_URL=""

# ── Redis (OPTIONAL) ──────────────────────────────────────────────────────
# The app fully works without Redis (settings/control/health flow through
# PostgreSQL). Setting REDIS_URL enables the instant pub/sub fast path and
# shared rate-limit counters. Leave empty to run without it.
REDIS_URL=""

# ── Auth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Optional Google OAuth ("Continue with Google" appears only when both are set).
# Google Cloud Console → Credentials → OAuth client (Web application) with
# authorized redirect URI:  <NEXTAUTH_URL>/api/auth/callback/google
# Google sign-in only signs in the EXISTING administrator email — it never
# creates accounts.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Encryption ────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of bot wallet keys.
# Generate with: openssl rand -hex 32
# NEVER commit this. Rotating it invalidates stored encrypted keys.
WALLET_ENCRYPTION_KEY=""

# ── Solana ────────────────────────────────────────────────────────────────
# NEEDED FOR THE SCANNER TO DETECT TOKENS. The public mainnet endpoint rejects
# the realtime scanner websocket (HTTP 403) and rate-limits polling, so the
# token list stays empty. Use a dedicated RPC (Helius/Triton/QuickNode) — a free
# Helius key works — and set the matching wss endpoint as SOLANA_WS_URL.
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_WS_URL="wss://api.mainnet-beta.solana.com"
# Optional: Helius API key enables richer holder/transaction analysis
HELIUS_API_KEY=""
# Temporary pipeline debugging: SCANNER_DEBUG=1 logs every scanner stage —
# poll cycles + cursor, each signature's extraction outcome, DB insert vs
# already-known (with total row count), and /api/tokens result counts.
# Leave unset in normal operation (verbose).
SCANNER_DEBUG=""

# ── Narrative intelligence (all optional) ─────────────────────────────────
# The narrative engine always runs on free sources (DexScreener socials,
# Reddit public search, Telegram public pages). These keys add sources:
# X/Twitter mention counts (requires a paid API tier with the counts endpoint)
TWITTER_BEARER_TOKEN=""
# AI-assisted meme-quality assessment (one small request per token).
# Without a key, meme scores use observable spread signals only.
ANTHROPIC_API_KEY=""
# Model for meme assessment (default claude-opus-4-8; set claude-haiku-4-5
# to cut cost on high-volume scanning).
ANTHROPIC_MODEL=""

# ── Notifications (all optional) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
DISCORD_WEBHOOK_URL=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
NOTIFY_EMAIL_TO=""
