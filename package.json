{
  "name": "pumpfun-migration-trader",
  "version": "1.0.0",
  "private": true,
  "description": "Automated trading platform for newly migrated Pump.fun tokens on Raydium — scanner, scoring engine, risk-managed executor, and dashboard.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "engine": "tsx src/engine/index.ts",
    "engine:paper": "TRADING_MODE=paper tsx src/engine/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@solana/web3.js": "^1.95.8",
    "bcryptjs": "^2.4.3",
    "bs58": "^6.0.0",
    "ioredis": "^5.4.1",
    "lightweight-charts": "^4.2.1",
    "next": "^14.2.21",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
