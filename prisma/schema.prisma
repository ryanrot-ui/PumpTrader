generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // App runtime uses DATABASE_URL (Neon's pooled endpoint is fine for queries).
  url      = env("DATABASE_URL")
  // Schema application (`prisma db push`) needs a DIRECT connection: Neon's
  // pooled endpoint (PgBouncer) cannot take the advisory lock / run the DDL
  // that push requires, which silently leaves the database with no tables.
  // DIRECT_URL should be the non-pooled Neon URL (host without `-pooler`).
  // Falls back to DATABASE_URL when unset (e.g. plain Postgres in Docker).
  directUrl = env("DIRECT_URL")
}

// ── Users & auth ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String? // argon2id (legacy bcrypt verified & upgraded on login)
  name         String?
  // Optional TOTP 2FA. The secret is AES-256-GCM encrypted at rest and is
  // only decrypted server-side during code verification.
  totpSecret  String?
  totpEnabled Boolean  @default(false)
  createdAt   DateTime @default(now())
  settings    Settings?
  wallets     Wallet[]
}

// ── Wallets ─────────────────────────────────────────────────────────────────

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicKey String   @unique
  label     String   @default("Bot wallet")
  // AES-256-GCM ciphertext of the secret key (iv:tag:data, hex). Null for
  // watch-only wallets (e.g. a connected Phantom address).
  encryptedKey String?
  isWatchOnly  Boolean @default(false)
  createdAt    DateTime @default(now())
}

// ── Live-editable bot settings (one row per user) ───────────────────────────

model Settings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Buying
  buyAmountSol        Float  @default(0.1)
  confidenceThreshold Int    @default(85)
  minLiquiditySol     Float  @default(50)
  maxLiquiditySol     Float? // null = no ceiling
  minMarketCapUsd     Float  @default(50000)
  maxMarketCapUsd     Float  @default(2000000)
  minHolders          Int    @default(100)
  minVolume5mUsd      Float  @default(5000)
  minBuyPressure      Float  @default(1.2) // minimum buy/sell ratio
  maxWhalePct         Float  @default(15) // max single-holder % of supply
  maxDevPct           Float  @default(10) // max developer holding %
  maxSlippageBps      Int    @default(300)

  // Selling — scalping defaults: take small profits fast, cut losers faster
  takeProfitPct   Float   @default(12) // quick scalp target
  stopLossPct     Float   @default(6) // tight loss cut
  trailingStopPct Float?  @default(5) // lock gains once in profit
  maxHoldMinutes  Int?    @default(10) // never marry a position
  sellPortionPct  Float   @default(100) // % of position sold at TP

  // Momentum exits (scalping): leave when the setup dies, before the dump.
  // null = disabled.
  exitMinBuySellRatio  Float? @default(0.75) // exit when 5m buys/sells falls below
  exitVolumeFadePct    Float? @default(65) // exit when 5m volume fades ≥ this % vs entry
  exitLiquidityDropPct Float  @default(25) // emergency exit when liquidity drains ≥ this %

  // Entry timing (anti-chase): never buy a move that already happened.
  // null = gate disabled.
  maxEntryPriceChange5mPct Float? @default(35) // reject if price already +this% in 5m
  maxEntryPriceChange1hPct Float? @default(175) // reject if price already +this% in 1h
  requireRisingMomentum    Boolean @default(false) // hard-require accelerating momentum

  // Adaptive exits
  letWinnersRun       Boolean @default(true) // defer TP while buy pressure is strong; trail protects
  adaptiveTrailing    Boolean @default(true) // tighten the trail as unrealized profit grows
  cutWeakAfterMinutes Float?  @default(4) // cut flat/losing positions with dead momentum after N min (null = off)

  // Learning analytics: auto-apply the optimizer's recommended scoring
  // weights each time a strategy report is generated.
  autoRebalanceWeights Boolean @default(false)
  reportEveryTrades    Int     @default(500) // auto strategy report cadence (closed trades)

  // Risk
  maxSolPerTrade    Float @default(0.25)
  maxOpenPositions  Int   @default(3)
  maxDailyLossSol   Float @default(1)
  dailyProfitTarget Float? // SOL; null = disabled
  maxExposureSol    Float @default(1)
  lossCooldownMin   Int   @default(15)

  // Execution
  priorityFeeLamports Int? // null = auto priority fee
  retryCount          Int  @default(2) // swap retry attempts on transient failure
  scannerIntervalSec  Int  @default(15) // watchlist re-evaluation cadence

  // Optional override of the scoring engine's metric weights (JSON object
  // matching ScoringWeights; null = built-in defaults)
  scoringWeights Json?

  // Narrative intelligence gates (null = gate disabled). Buys additionally
  // require these when set; scores are 0–100.
  minNarrativeScore Int?
  minMemeScore      Int?
  maxRugRiskScore   Int?
  // off | alert | execute — what to do when an open position's narrative
  // deteriorates (alert logs+notifies; execute market-exits).
  narrativeExitMode String @default("off")
  // Optional override of narrative component weights (JSON matching
  // NarrativeWeights; null = built-in defaults)
  narrativeWeights Json?

  // Engine
  botEnabled   Boolean @default(false)
  paperTrading Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// ── Scanner output ──────────────────────────────────────────────────────────

model DetectedToken {
  id          String   @id @default(cuid())
  mint        String   @unique
  symbol      String?
  name        String?
  poolAddress String?
  migratedAt  DateTime
  detectedAt  DateTime @default(now())

  // Display metadata (from DexScreener pair info; refreshed on evaluation)
  imageUrl    String?
  websiteUrl  String?
  twitterUrl  String?
  telegramUrl String?

  // latest evaluation
  score      Int?
  verdict    String? // BUY_CANDIDATE | WATCH | REJECTED | BOUGHT | IGNORED
  rejectionReasons String[] @default([])
  // Full rule-by-rule execution decision (RuleResult[] from trading/rules.ts)
  decisionTrace Json?
  // 0-100: share of decision inputs that had data at evaluation time
  confidence Int?

  // Latest narrative-intelligence evaluation (full history in narrative[])
  narrativeScore Int?
  memeScore      Int?
  rugRiskScore   Int?

  snapshots TokenSnapshot[]
  scores    ScoreRecord[]
  narrative NarrativeSnapshot[]
  trades    Trade[]

  @@index([detectedAt])
  @@index([verdict])
}

model TokenSnapshot {
  id      String        @id @default(cuid())
  tokenId String
  token   DetectedToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  at      DateTime      @default(now())

  priceUsd     Float?
  liquiditySol Float?
  marketCapUsd Float?
  volume5mUsd  Float?
  holderCount  Int?
  txPerMinute  Float?
  buySellRatio Float?

  @@index([tokenId, at])
}

model ScoreRecord {
  id      String        @id @default(cuid())
  tokenId String
  token   DetectedToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  at      DateTime      @default(now())

  total      Int
  // full per-metric breakdown, green flags, red flags — kept as JSON so the
  // scoring engine can evolve without migrations
  breakdown  Json
  greenFlags String[]
  redFlags   String[]
  critical   Boolean @default(false) // any critical red flag present

  @@index([tokenId, at])
}

// One narrative-intelligence evaluation of a token: raw social signals plus
// the derived scores and their explanations. History enables velocity/growth
// calculations; archived on the same schedule as TokenSnapshot.
model NarrativeSnapshot {
  id      String        @id @default(cuid())
  tokenId String
  token   DetectedToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  at      DateTime      @default(now())

  // Raw signals (null = source unavailable; scored neutral, never bullish)
  redditPosts24h   Int?
  redditEngagement Int? // sum of upvotes+comments across recent posts
  telegramMembers  Int?
  xMentions24h     Int?
  boostsActive     Int? // DexScreener paid promotion count
  hasTwitter       Boolean @default(false)
  hasTelegram      Boolean @default(false)
  hasWebsite       Boolean @default(false)

  // Derived scores (0–100) + explanation payloads
  memeScore      Int?
  narrativeScore Int?
  rugRiskScore   Int?
  sentiment      Float? // -1..1 from post titles; null = no data
  // { bullishFactors: string[], bearishFactors: string[],
  //   meme: string, narrative: string, rug: string, signals: {...} }
  report Json?

  @@index([tokenId, at])
}

// ── Trading ─────────────────────────────────────────────────────────────────

model Trade {
  id      String  @id @default(cuid())
  // Optional so archiving old scanner rows can never orphan or delete the
  // financial record — trades outlive their DetectedToken.
  tokenId String?
  token   DetectedToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  side        String // BUY | SELL
  paper       Boolean  @default(true)
  mint        String   @default("")
  symbol      String?
  amountSol   Float
  tokenQty    Float
  priceUsd    Float?
  slippageBps Int?
  signature   String? // tx signature (null for paper trades)
  reason      String // human-readable explanation of why this trade fired

  // Execution telemetry
  latencyMs           Int? // detection→confirmation wall time for this swap
  rpcUrl              String?
  priorityFeeLamports Int?
  retries             Int     @default(0)
  error               String? // last error message if any attempt failed

  createdAt DateTime @default(now())

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  @@index([createdAt])
  @@index([positionId])
  @@index([mint])
}

model Position {
  id     String  @id @default(cuid())
  mint   String
  symbol String?

  // Duplicate-buy guard enforced by the DATABASE, not just app logic:
  // set to the mint while OPEN, cleared on close. The unique constraint
  // makes a second concurrent open position on the same mint impossible.
  openKey String? @unique

  status        String    @default("OPEN") // OPEN | CLOSED
  paper         Boolean   @default(true)
  entrySol      Float
  entryPriceUsd Float?
  tokenQty      Float
  peakPriceUsd  Float? // for trailing stop
  exitSol       Float?
  exitPriceUsd  Float?
  pnlSol        Float?
  pnlPct        Float?
  entryReason   String
  exitReason    String?

  // Excursion tracking (updated on every monitor tick):
  // best unrealized gain and worst peak-to-trough drop seen while open.
  maxUnrealizedPnlPct Float?
  maxDrawdownPct      Float?
  // Pool liquidity at entry — baseline for the liquidity-drop rug signal.
  entryLiquidityUsd   Float?
  // 5m volume at entry — baseline for the volume-fade momentum exit.
  entryVolume5mUsd    Float?
  // Snapshot of every signal present at entry (scores + raw social/on-chain
  // readings) — compared against the outcome by the learning analytics.
  entrySignals Json?

  // Snapshot of the analysis that triggered the entry
  scannerScore     Int?
  scoreExplanation String?

  openedAt DateTime  @default(now())
  closedAt DateTime?

  trades Trade[]

  @@index([status])
  @@index([openedAt])
  @@index([mint])
}

// ── Engine coordination ─────────────────────────────────────────────────────

// Singleton row (id = "engine"). The database is the source of truth for
// engine state, so the web app and the worker coordinate without requiring
// Redis. When Redis IS configured it is used as a pub/sub fast path only.
model EngineState {
  id          String    @id @default("engine")
  status      String    @default("stopped") // running | stopped | emergency_stopped
  readOnly    Boolean   @default(false)
  heartbeatAt DateTime?
  health      Json? // rpc latency/endpoint, scans/min, watchlist size, memory…
  // One-shot control command (emergency_stop | resume) written by the web
  // app; the engine consumes and clears it within one poll interval.
  controlRequest     String?
  controlRequestedAt DateTime?
  updatedAt          DateTime @updatedAt
}

// ── Logging & metrics ───────────────────────────────────────────────────────

model LogEntry {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  level     String // debug | info | warn | error
  source    String // scanner | scoring | executor | risk | api | notify
  message   String
  meta      Json?

  @@index([at])
  @@index([level])
  @@index([source])
}

// Auto-generated strategy performance report: full trade statistics, bucket
// analyses, and the weight-optimizer's recommendation at generation time.
// Written by the engine every `reportEveryTrades` closed trades and on demand
// via POST /api/analytics.
model StrategyReport {
  id             String   @id @default(cuid())
  at             DateTime @default(now())
  mode           String   @default("all") // paper | live | all
  tradesAnalyzed Int
  trigger        String   @default("auto") // auto | manual
  // Full TradeStats payload (learning/tradeStats.ts)
  stats Json
  // Optimizer output: recommended weights + per-metric evidence + prose
  recommendations Json?
  // Whether autoRebalanceWeights applied the recommendation to settings
  weightsApplied Boolean @default(false)

  @@index([at])
}

model DailyStats {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  realizedSol Float    @default(0)
  trades      Int      @default(0)
  wins        Int      @default(0)
  losses      Int      @default(0)
  scanned     Int      @default(0)
  bought      Int      @default(0)
  rejected    Int      @default(0)
}
